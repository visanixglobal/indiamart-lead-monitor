# IndiaMART Credentials
# Your GLUSRID (found in request body of getBLDisplayData)
GLUSRID=80627141
# Paste the full Cookie header from DevTools → Network → any getBLDisplayData request → Headers → Cookie
INDIAMART_COOKIE=

# Monitoring interval in seconds (default: 60)
POLL_INTERVAL=60

# Auto-Shortlist (bookmark leads — NO credits consumed, NO contact made)
AUTO_SHORTLIST=false
# Minimum probable order value in ₹ Lakh to trigger auto-shortlist (0 = all leads)
SHORTLIST_MIN_VALUE=0

# Telegram Alerts (currently banned in India — will work when lifted)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ntfy.sh Push Notifications (FREE — works right now, no signup needed)
# 1. Install "ntfy" app on iPhone from App Store
# 2. Tap + → enter your topic name below → Subscribe
# 3. Use a unique name so others can't guess it
# Example: visanix-leads-x7k2m9
NTFY_TOPIC=
