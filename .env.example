# IndiaMART credentials are hardcoded in app/config.py
# Update _INDIAMART_COOKIE in config.py when the session expires, then redeploy.
# _GLUSRID is your permanent seller ID (80627141) — no need to change.

# Monitoring interval in seconds (default: 60)
POLL_INTERVAL=60

# Quiet Hours in UTC (server timezone)
# IST 1:00 AM  = UTC 19:30 → use 19
# IST 8:00 AM  = UTC 02:30 → use 2
QUIET_HOURS_START=19
QUIET_HOURS_END=2

# Auto-Shortlist (bookmark leads — NO credits consumed, NO contact made)
AUTO_SHORTLIST=false
SHORTLIST_MIN_VALUE=0

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ntfy.sh Push Notifications (FREE — no signup needed)
# Install ntfy app → subscribe to your topic name
NTFY_TOPIC=
